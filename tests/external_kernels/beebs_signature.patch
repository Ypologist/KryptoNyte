diff --git a/support/main.c b/support/main.c
index 1938ce7..10b4b50 100644
--- a/support/main.c
+++ b/support/main.c
@@ -24,6 +24,33 @@
    SPDX-License-Identifier: GPL-3.0-or-later */
 
 #include "support.h"
+#include <stdint.h>
+
+__attribute__((section(".signature")))
+volatile uint32_t zeronyte_signature_buffer[32];
+
+__attribute__((section(".signature")))
+static volatile uint32_t zeronyte_signature_end_marker;
+
+__attribute__((section(".tohost")))
+volatile uint64_t tohost = 0;
+
+__attribute__((section(".tohost")))
+volatile uint64_t fromhost = 0;
+
+__asm__(".globl begin_signature\n"
+        "begin_signature = zeronyte_signature_buffer\n");
+__asm__(".globl end_signature\n"
+        "end_signature = zeronyte_signature_end_marker\n");
+
+static void
+record_signature (uint32_t iterations, uint32_t last_result, uint32_t correct)
+{
+  zeronyte_signature_buffer[0] = last_result;
+  zeronyte_signature_buffer[1] = correct;
+  zeronyte_signature_buffer[2] = iterations;
+  zeronyte_signature_buffer[3] = 0xBEEB500D;
+}
 
 
 extern int initialise_benchmark (void);
@@ -52,6 +79,8 @@ main (int   argc __attribute__ ((unused)),
   /* bmarks that use arrays will check a global array rather than int result */
 
   correct = verify_benchmark (result);
+  record_signature (REPEAT_FACTOR, (uint32_t) result, (uint32_t) correct);
+  tohost = 1;
 
   return (!correct);
 
