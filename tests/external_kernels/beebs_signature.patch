+
+static void
+record_rng_trace(uint32_t dividend, uint32_t remainder)
+{
+  if (zeronyte_rng_trace_idx < 8) {
+    zeronyte_rng_dividend_trace[zeronyte_rng_trace_idx] = dividend;
+    zeronyte_rng_remainder_trace[zeronyte_rng_trace_idx] = remainder;
+  }
+  zeronyte_rng_trace_idx++;
+}
+
+static void
+record_cnt_debug(void)
+{
+  zeronyte_signature_buffer[4] = (uint32_t)Seed;
+  zeronyte_signature_buffer[5] = (uint32_t)Postotal;
+  zeronyte_signature_buffer[6] = (uint32_t)Negtotal;
+  zeronyte_signature_buffer[7] = (uint32_t)Poscnt;
+  zeronyte_signature_buffer[8] = (uint32_t)Negcnt;
+  for (int i = 0; i < 8; ++i) {
+    zeronyte_signature_buffer[16 + i] = zeronyte_rng_dividend_trace[i];
+    zeronyte_signature_buffer[24 + i] = zeronyte_rng_remainder_trace[i];
+  }
+}
+
 
 
